title: Projects Map
layout: layouts/base.njk
permalink: "/projects-map/"
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

<div class="row align-items-end mb-4">
    <div class="col-lg-7">
        <span class="section-label" data-i18n="projectsMap.label">GLOBAL NETWORK</span>
        <h1 class="page-title mb-2" data-i18n="projectsMap.title">Projects Map</h1>
        <p class="text-muted small mb-3" data-i18n="projectsMap.intro">
            Explore how BirdNET is being used by researchers around the world. Select a project to locate it on the map.
        </p>
        <div class="dropdown" style="max-width: 400px;">
            <button class="btn btn-light border-0 shadow-sm rounded-3 w-100 text-start d-flex justify-content-between align-items-center" type="button" id="projectSelectorBtn" data-bs-toggle="dropdown" aria-expanded="false">
                <span data-i18n="projectsMap.jumpTo">Jump to a project (sorted A-Z)...</span>
                <i class="fa-solid fa-chevron-down small text-muted"></i>
            </button>
            <ul class="dropdown-menu shadow border-0 rounded-3 w-100 scrollable-menu" style="max-height: 400px; overflow-y: auto;" id="projectSelectorMenu">
                <!-- Populated via JS -->
            </ul>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="d-flex flex-wrap gap-3 justify-content-lg-end mb-2">
            <div class="legend-item"><i class="fa-solid fa-feather-pointed"></i> <span data-i18n="projectsMap.legend.birds">Birds</span></div>
            <div class="legend-item"><i class="fa-solid fa-paw"></i> <span data-i18n="projectsMap.legend.mammals">Mammals</span></div>
            <div class="legend-item"><i class="fa-solid fa-frog"></i> <span data-i18n="projectsMap.legend.frogs">Frogs</span></div>
            <div class="legend-item"><i class="fa-solid fa-droplet"></i> <span data-i18n="projectsMap.legend.marine">Marine Life</span></div>
        </div>
    </div>
</div>

<div class="card border-0 bg-transparent mb-5 position-relative overflow-hidden rounded-4 shadow-sm" style="min-height: 700px;">
  <div id="map-consent-overlay" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-light" style="z-index: 1000; background-color: #f8f9fa !important; background-image: radial-gradient(#dee2e6 1px, transparent 1px); background-size: 20px 20px;">
    <div class="text-center p-4 p-lg-5 shadow-lg rounded-4 bg-white mx-3 border" style="max-width: 500px;">
        <div class="icon-wrapper bg-primary text-white mx-auto mb-4" style="width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-map-location-dot h4 mb-0"></i>
        </div>
        <h3 class="h5 fw-bold mb-3" data-i18n="projectsMap.privacy.title">Map Privacy Notice</h3>
        <p class="text-muted small mb-4" data-i18n="projectsMap.privacy.desc">
            To display the interactive project map, we load map tiles from external providers (OpenStreetMap and CARTO). These providers may process your IP address and other browser data. 
        </p>
        <button type="button" class="btn btn-primary px-4 py-2 fw-bold" onclick="acceptMapConsent()" data-i18n="projectsMap.privacy.accept">Accept and Load Map</button>
        <div class="mt-3">
            <a href="/privacy/" class="text-muted small text-decoration-underline" data-i18n="projectsMap.privacy.learn">Learn more in our Privacy Policy</a>
        </div>
    </div>
  </div>
  <div id="projects-map" style="height: 700px; width: 100%;"></div>
</div>

<div class="row mb-5">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-lg-5">
            <h2 class="h4 fw-bold mb-4" data-i18n="projectsMap.add.title">How to add your project</h2>
            <p class="text-muted" data-i18n="projectsMap.add.desc">We want to highlight the many use cases and great projects in bioacoustics and conservation that use BirdNET in their workflow. We need your help to add more projects to the map and keep the information accurate.</p>
            
            <div class="row g-4 mt-2">
                <div class="col-md-6">
                    <div class="d-flex gap-3">
                        <div class="icon-wrapper sm bg-primary text-white p-0 d-flex align-items-center justify-content-center">
                            <i class="fa-brands fa-github h5 mb-0"></i>
                        </div>
                        <div>
                            <h3 class="h6 fw-bold mb-1" data-i18n="projectsMap.add.github">GitHub Pull Request</h3>
                            <p class="smaller text-muted mb-0"><span data-i18n="projectsMap.add.githubDesc">Submit a PR with a new entry in the</span> <a href="https://github.com/birdnet-team/BirdNET-Analyzer/blob/main/docs/projects_data.js" target="_blank" data-i18n="projectsMap.add.projectsData">projects data</a> <span data-i18n="projectsMap.add.file">file.</span></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex gap-3">
                        <div class="icon-wrapper sm bg-primary text-white p-0 d-flex align-items-center justify-content-center">
                            <i class="fa-solid fa-clipboard-list h5 mb-0"></i>
                        </div>
                        <div>
                            <h3 class="h6 fw-bold mb-1" data-i18n="projectsMap.add.form">Google Form</h3>
                            <p class="smaller text-muted mb-0"><span data-i18n="projectsMap.add.formDesc">Fill out our</span> <a href="https://forms.gle/z5aydVaRB9op3Tem9" target="_blank" data-i18n="projectsMap.add.formLink">Google Form</a> <span data-i18n="projectsMap.add.formSuffix">with your project details.</span></p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 pt-4 border-top">
                <h4 class="smaller text-uppercase fw-bold text-muted ls-1 mb-3" data-i18n="projectsMap.add.required">Required Information</h4>
                <div class="row row-cols-2 row-cols-md-3 g-2">
                    <div class="col small">Project name*</div>
                    <div class="col small">Org / Project lead*</div>
                    <div class="col small">Target species*</div>
                    <div class="col small">Region/Location*</div>
                    <div class="col small">Latitude*</div>
                    <div class="col small">Longitude*</div>
                </div>
                <p class="smaller text-muted mt-3 mb-0" data-i18n="projectsMap.add.requiredNote">* Required fields for a valid map marker.</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 bg-primary text-white p-4 rounded-4 h-100 shadow-sm">
            <h3 class="h5 fw-bold mb-3" data-i18n="projectsMap.accurate.title">Keep it accurate</h3>
            <p class="small text-white text-opacity-75 mb-4" data-i18n="projectsMap.accurate.desc">If you would like to update a project or find that some information is incorrect, please let us know through any of the contribution channels.</p>
            <a href="https://github.com/birdnet-team/BirdNET-Analyzer" target="_blank" class="btn btn-light btn-sm mt-auto shadow-sm" data-i18n="projectsMap.accurate.viewGithub">View on GitHub</a>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="{{ '/js/projects.js' | url }}"></script>
<script id="project-data" type="application/json">
  {{ projects | dump | safe }}
</script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const dataContainer = document.getElementById('project-data');
    const menu = document.getElementById('projectSelectorMenu');
    
    if (dataContainer && menu) {
      // Parse data and filter for valid coordinates
      let projectData = JSON.parse(dataContainer.textContent)
        .filter(p => p.Latitude != null && p.Longitude != null);
      
      // Sort alphabetically by Project name
      projectData.sort((a, b) => a['Project name'].localeCompare(b['Project name']));
      
      // Check for consent with a more specific key
      const consentKey = 'birdnet_map_consent_2024';
      
      if (localStorage.getItem(consentKey) === 'true') {
        initMapUI(projectData);
      }

      // Handle consent acceptance
      window.acceptMapConsent = function() {
        localStorage.setItem(consentKey, 'true');
        initMapUI(projectData);
      };

      function initMapUI(data) {
        console.log('Consent detected or given, loading map...');
        // Hide overlay
        const overlay = document.getElementById('map-consent-overlay');
        if (overlay) {
            overlay.style.opacity = '0';
            setTimeout(() => {
                overlay.classList.add('d-none');
                overlay.style.display = 'none';
            }, 300);
        }
        
        // Initialize map
        initProjectsMap(data);
      }
      
      // Font Awesome mapping
      const iconMap = {
          'feather': 'fa-solid fa-feather-pointed',
          'paw': 'fa-solid fa-paw',
          'frog': 'fa-solid fa-frog',
          'water': 'fa-solid fa-droplet',
          'bug': 'fa-solid fa-bug',
          'fish': 'fa-solid fa-fish',
          'leaf': 'fa-solid fa-leaf',
          'cog': 'fa-solid fa-gear'
      };
      
      // Populate dropdown menu
      projectData.forEach((project, index) => {
          const li = document.createElement('li');
          const iconClass = iconMap[project['Species Icon']] || 'fa-solid fa-location-dot';
          const countrySuffix = project.Country ? ` <small class="text-muted">(${project.Country})</small>` : '';
          
          li.innerHTML = `
              <button class="dropdown-item d-flex align-items-center gap-3 py-2" type="button" onclick="focusAndClose(${index}, '${project['Project name']}')">
                  <div class="d-flex align-items-center justify-content-center bg-light rounded-circle" style="width: 28px; height: 28px; flex-shrink: 0;">
                      <i class="${iconClass} text-primary" style="font-size: 0.85rem;"></i>
                  </div>
                  <div class="text-truncate">
                      <span class="d-block text-truncate small fw-medium">${project['Project name']}</span>
                      <span class="d-block x-small text-muted">${project.Country || 'Global'}</span>
                  </div>
              </button>
          `;
          menu.appendChild(li);
      });

      // Helper to handle click and update button text
      window.focusAndClose = function(index, name) {
          const consentKey = 'birdnet_map_consent_2024';
          if (localStorage.getItem(consentKey) !== 'true') {
              // Scroll to the disclaimer if they try to jump to a project without consent
              document.getElementById('map-consent-overlay').scrollIntoView({ behavior: 'smooth', block: 'center' });
              return;
          }
          focusProject(index);
          const btnSpan = document.getElementById('projectSelectorBtn').querySelector('span');
          btnSpan.textContent = name;
      };
    }
  });
</script>
