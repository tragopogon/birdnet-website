<!-- How it works -->
<section class="py-5">
  <div class="container py-lg-4">
    <div class="card bg-dark text-white border-0 shadow-lg overflow-hidden position-relative rounded-4">
      <div class="card-body p-4 p-lg-5 position-relative" style="z-index: 2;">
        <div class="row mb-5 justify-content-center text-center">
          <div class="col-lg-8">
            <span class="section-label section-label-dark mx-auto">Architecture</span>
            <h2 class="display-6 fw-bold mb-3">How BirdNET works</h2>
            <p class="text-white text-opacity-75">BirdNET processes raw acoustic data through a multi-stage pipeline designed for ecological accuracy. By transforming varying soundscapes into standardized feature representations, the system can isolate and identify subtle vocal signatures across thousands of species while accounting for biogeographical variations in species distribution.</p>
          </div>
        </div>
        <div class="row g-4 align-items-stretch">
          <div class="col-md-3">
            <div class="h-100 p-4 card-glass">
              <div class="icon-wrapper mb-4">
                <i class="bi bi-mic"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Signal Extraction</h3>
              <p class="small text-white text-opacity-50 mb-0">Audio is resampled and segmented into 3-second windows, capturing the temporal structure of most avian vocalizations.</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="h-100 p-4 card-glass">
              <div class="icon-wrapper mb-4">
                <i class="bi bi-soundwave"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Spectrogram Mapping</h3>
              <p class="small text-white text-opacity-50 mb-0">Raw acoustic signals are transformed into log-scaled Mel-spectrograms, highlighting frequency patterns for neural processing.</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="h-100 p-4 card-glass">
              <div class="icon-wrapper mb-4">
                <i class="bi bi-cpu"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Neural Inference</h3>
              <p class="small text-white text-opacity-50 mb-0">A deep ResNet model analyzes spectrogram features, trained on millions of expert-vetted bird recordings from around the globe.</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="h-100 p-4 card-glass">
              <div class="icon-wrapper mb-4">
                <i class="bi bi-geo-alt"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Contextual Filters</h3>
              <p class="small text-white text-opacity-50 mb-0">Machine learning results are refined using location and date metadata—incorporating <strong>biogeographical priors</strong> to maximize precision.</p>
            </div>
          </div>
        </div>
        <div class="text-center mt-5">
          <p class="small text-white text-opacity-50 mb-0">
            Read the technical details in our <a href="https://doi.org/10.1016/j.ecoinf.2021.101236" target="_blank" class="text-white text-decoration-underline">primary publication</a> or explore the <a href="{{ '/about/' | url }}" class="text-white text-decoration-underline">recognition workflow</a>.
          </p>
        </div>
      </div>
      <!-- Background glow effect -->
      <div class="position-absolute top-50 start-50 translate-middle" style="width: 600px; height: 600px; background: radial-gradient(circle, rgba(26, 95, 180, 0.15) 0%, transparent 75%); filter: blur(80px); z-index: 1;"></div>
    </div>
  </div>
</section>

