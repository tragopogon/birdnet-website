<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title or "BirdNET" }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {# Bootstrap CSS (local only) #}
  <link rel="stylesheet" href="{{ '/vendor/bootstrap/bootstrap.min.css' | url }}">
  <link rel="stylesheet" href="{{ '/css/main.css' | url }}">
  <link rel="stylesheet" href="{{ '/vendor/bootstrap-icons/bootstrap-icons.css' | url }}">
  <link rel="stylesheet" href="{{ '/vendor/fontawesome/css/all.min.css' | url }}">

  <link rel="icon" type="image/png" href="{{ '/favicon.png' | url }}">

  {# i18n translations embedded inline - only non-English languages needed #}
  {# English content is already in the HTML as the default/fallback #}
  <script>
    window.__i18n = {
      de: {{ i18n.de | dump | safe }},
      es: {{ i18n.es | dump | safe }},
      fr: {{ i18n.fr | dump | safe }},
      it: {{ i18n.it | dump | safe }},
      'pt-BR': {{ i18n['pt-BR'] | dump | safe }},
      pt: {{ i18n.pt | dump | safe }},
      ru: {{ i18n.ru | dump | safe }},
      pl: {{ i18n.pl | dump | safe }},
      cs: {{ i18n.cs | dump | safe }},
      'zh-CN': {{ i18n['zh-CN'] | dump | safe }},
      tlh: {{ i18n.tlh | dump | safe }}
    };
  </script>
</head>
<body class="d-flex flex-column min-vh-100">

  {% include "partials/header.njk" %}

  <main class="flex-fill">
    <div class="{% if containerClass is defined %}{{ containerClass }}{% else %}container py-4{% endif %}">
      {{ content | safe }}
    </div>
  </main>

  {% include "partials/footer.njk" %}

  <script src="{{ '/vendor/bootstrap/bootstrap.bundle.min.js' | url }}"></script>
  <script src="{{ '/js/i18n.js' | url }}"></script>
</body>
</html>
