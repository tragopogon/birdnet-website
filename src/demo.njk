/* -----------------------------
   Microphone Recording
----------------------------- */
let mediaRecorder = null;
let audioChunks = [];
let recordingStartTime = null;
let recordingTimerInterval = null;
const MAX_RECORDING_SECONDS = 300; // 5 minutes max

function formatRecordingTime(seconds) {
  const mins = Math.floor(seconds / 60);
  const secs = Math.floor(seconds % 60);
  return mins + ':' + String(secs).padStart(2, '0');
}

function updateRecordingTimer() {
  if (!recordingStartTime) return;
  const elapsed = (Date.now() - recordingStartTime) / 1000;
  $('#recordingTimer').text(formatRecordingTime(elapsed));
  
  // Auto-stop at max duration
  if (elapsed >= MAX_RECORDING_SECONDS) {
    stopRecording();
  }
}

function showRecordingUI() {
  $('#dropzoneHeader').addClass('d-none');
  $('#dropzoneContent').hide();
  $('#recordingUI').removeClass('d-none');
  $('#recordingTimer').text('0:00');
}

function hideRecordingUI() {
  $('#recordingUI').addClass('d-none');
  $('#dropzoneContent').show();
}

async function startRecording() {
  try {
    // Request microphone access with 48kHz sample rate for best BirdNET compatibility
    const stream = await navigator.mediaDevices.getUserMedia({
      audio: {
        sampleRate: 48000,
        channelCount: 1,
        echoCancellation: false,
        noiseSuppression: false,
        autoGainControl: false
      }
    });
    
    audioChunks = [];
    
    // Use audio/webm for better compatibility; we'll decode it to PCM later
    const mimeType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus') 
      ? 'audio/webm;codecs=opus' 
      : 'audio/webm';
    
    mediaRecorder = new MediaRecorder(stream, { mimeType });
    
    mediaRecorder.ondataavailable = (e) => {
      if (e.data.size > 0) {
        audioChunks.push(e.data);
      }
    };
    
    mediaRecorder.onstop = async () => {
      // Stop all tracks
      stream.getTracks().forEach(track => track.stop());
      
      // Clear timer
      if (recordingTimerInterval) {
        clearInterval(recordingTimerInterval);
        recordingTimerInterval = null;
      }
      
      // Only process if we have audio data (not cancelled)
      if (audioChunks.length > 0) {
        const blob = new Blob(audioChunks, { type: mimeType });
        lastRecordingBlob = blob; // Store for download
        const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);
        const file = new File([blob], `recording_${timestamp}.webm`, { type: mimeType });
        hideRecordingUI();
        await loadAudioFile(file, true); // Pass isRecording=true
      } else {
        hideRecordingUI();
      }
    };
    
    mediaRecorder.onerror = (e) => {
      console.error('MediaRecorder error:', e);
      $('#statusLine').html('<span class="text-danger"><i class="bi bi-exclamation-circle me-1"></i>Recording error: ' + (e.error?.message || 'Unknown error') + '</span>');
      cancelRecording();
    };
    
    // Start recording
    mediaRecorder.start(1000); // Collect data every second
    recordingStartTime = Date.now();
    showRecordingUI();
    
    // Update timer every second
    recordingTimerInterval = setInterval(updateRecordingTimer, 1000);
    
    $('#statusLine').html('<i class="bi bi-mic-fill text-danger me-1"></i>Recording... Speak or play bird sounds near your microphone.');
    
  } catch (err) {
    console.error('Microphone access error:', err);
    let msg = 'Could not access microphone';
    if (err.name === 'NotAllowedError') {
      msg = 'Microphone access denied. Please allow microphone access in your browser settings.';
    } else if (err.name === 'NotFoundError') {
      msg = 'No microphone found. Please connect a microphone and try again.';
    } else if (err.name === 'NotReadableError') {
      msg = 'Microphone is in use by another application.';
    }
    $('#statusLine').html('<span class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>' + msg + '</span>');
  }
}

function stopRecording() {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') {
    mediaRecorder.stop();
  }
}

function cancelRecording() {
  audioChunks = []; // Clear chunks so onstop doesn't process them
  
  if (recordingTimerInterval) {
    clearInterval(recordingTimerInterval);
    recordingTimerInterval = null;
  }
  
  if (mediaRecorder) {
    if (mediaRecorder.state !== 'inactive') {
      // Stop the media recorder (which will also stop the stream in onstop)
      mediaRecorder.stream.getTracks().forEach(track => track.stop());
      mediaRecorder.stop();
    }
    mediaRecorder = null;
  }
  
  hideRecordingUI();
  $('#statusLine').html('Recording cancelled.');
}

$('#recordBtn').on('click', startRecording);
$('#stopRecordBtn').on('click', stopRecording);
$('#cancelRecordBtn').on('click', cancelRecording);

$('#fileupload').on('change', async e => {
  const file = e.currentTarget.files[0];
  if (!file) return;
  await loadAudioFile(file);
});

$('#runBtn').on('click', async () => {
  if (!lastPCM) { 
    $('#statusLine').html('<span class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>Please load audio first.</span>'); 
    return; 
  }
  
  setRunButtonLoading(true);
  clearResults();
  const selectedLang = $('#langSelect').val() || 'auto';
  
  if (!worker || !workerLoaded || selectedLang !== currentWorkerLang) {
    showProgress(5, _t('demo.status.initModel', 'Initializing model...'));
    newWorker(selectedLang);
    await waitForLoaded();
  }
  
  // Only apply geo filter if enabled and coordinates are set
  if (isLocationFilterEnabled() && hasValidLocation()) {
    const lat = parseFloat($('#latInput').val());
    const lon = parseFloat($('#lonInput').val());
    showProgress(50, _t('demo.status.applyingLocation', 'Applying location filter...'));
    worker.postMessage({ message:'area-scores', latitude: lat, longitude: lon });
  }
  
  const overlapSec = parseFloat($('#overlapSelect').val() || '0.0');
  showProgress(60, _t('demo.status.analyzing', 'Analyzing audio...'));
  // Transfer the buffer to the worker to avoid doubling memory on iOS
  const pcmCopy = lastPCM.slice();
  worker.postMessage({ message:'predict', pcmAudio: pcmCopy, overlapSec }, [pcmCopy.buffer]);
});

/* Location filter toggle */
$('#useLocationFilter').on('change', function() {
  const enabled = $(this).is(':checked');
  if (enabled) {
    $('#locationInputs').slideDown(200);
    $('#locationHelp').slideDown(200);
  } else {
    $('#locationInputs').slideUp(200);
    $('#locationHelp').slideUp(200);
  }
  updateLocationStatus();
  
  // Re-render results if we have them (to apply/remove geo filter)
  if (pooledResults) {
    renderResults();
  }
});

/* Location input changes */
$('#latInput, #lonInput').on('input', function() {
  updateLocationStatus();
});

/* Geolocation button */
$('#geolocateBtn').on('click', function() {
  const btn = $(this);
  const originalContent = btn.html();
  
  if (!navigator.geolocation) {
    $('#statusLine').html('<span class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>Geolocation not supported by your browser.</span>');
    return;
  }
  
  btn.prop('disabled', true).html('<i class="bi bi-arrow-repeat spin me-1"></i>Detecting...');
  
  navigator.geolocation.getCurrentPosition(
    (position) => {
      $('#latInput').val(position.coords.latitude.toFixed(4));
      $('#lonInput').val(position.coords.longitude.toFixed(4));
      btn.prop('disabled', false).html(originalContent);
      updateLocationStatus();
      $('#statusLine').html('<i class="bi bi-check-circle text-success me-1"></i>Location detected successfully.');
    },
    (error) => {
      btn.prop('disabled', false).html(originalContent);
      let msg = 'Could not get location';
      if (error.code === 1) msg = 'Location access denied. Please allow location access in your browser.';
      else if (error.code === 2) msg = 'Location unavailable';
      else if (error.code === 3) msg = 'Location request timed out';
      $('#statusLine').html('<span class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>' + msg + '</span>');
    },
    { enableHighAccuracy: false, timeout: 10000 }
  );
});

/* Confidence threshold slider */
$('#confidenceThreshold').on('input', function() {
  const val = parseFloat($(this).val());
  $('#confidenceValue').text(Math.round(val * 100) + '%');
  // Re-render results if we have them
  if (pooledResults) {
    renderResults();
  }
});

/* WaveSurfer seek interaction */
$('#ws-container').on('mousedown', function(e) {
  if (!ws) return;
  const x = e.clientX + window.scrollX - $(this).offset().left;
  ws.seekTo(Math.min(Math.max(x / $(this).width(), 0), 1));
});

/* Player controls */
$('#playBtn').on('click', () => ws && ws.play());
$('#pauseBtn').on('click', () => ws && ws.pause());
$('#restartBtn').on('click', () => { if (ws) { ws.seekTo(0); ws.play(); } });

/* Drag & drop */
const dz = $('#dropzone');
dz.on('dragenter dragover', e => { e.preventDefault(); e.stopPropagation(); dz.addClass('upload-dropzone-hover'); });
dz.on('dragleave', e => { e.preventDefault(); e.stopPropagation(); dz.removeClass('upload-dropzone-hover'); });
dz.on('drop', async e => {
  e.preventDefault(); e.stopPropagation();
  dz.removeClass('upload-dropzone-hover');
  const file = e.originalEvent.dataTransfer.files[0];
  if (file) {
    $('#fileupload')[0].files = e.originalEvent.dataTransfer.files;
    await loadAudioFile(file);
  }
});

/* -----------------------------
   CSV export
----------------------------- */
$('#downloadCsvBtn').on('click', () => {
  if (!segmentPredictions) return;
  
  const threshold = getConfidenceThreshold();
  const useGeo = areaModelLoaded && isLocationFilterEnabled() && hasValidLocation();
  let rows = ['start,end,scientific_name,common_name,confidence'];
  
  segmentPredictions.forEach(seg => {
    const filtered = seg.preds
      .filter(p => {
        const conf = useGeo && p.geoscore <= GEO_THRESH ? 0 : p.confidence;
        return conf >= threshold;
      })
      .sort((a, b) => b.confidence - a.confidence);
    
    filtered.forEach(p => {
      const scientificName = (p.sciName || p.name).replace(/"/g, '""');
      const commonName = (p.nameI18n || p.name).replace(/"/g, '""');
      rows.push(`${seg.start.toFixed(3)},${seg.end.toFixed(3)},"${scientificName}","${commonName}",${p.confidence.toFixed(4)}`);
    });
  });
  
  if (rows.length === 1) rows.push('0,0,"(no detections)","(no detections)",0');
  
  const blob = new Blob([rows.join('\n')], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = currentFileName + '_BirdNET_Results.csv';
  document.body.appendChild(a);
  a.click();
  setTimeout(() => {
    URL.revokeObjectURL(a.href);
    a.remove();
  }, 100);
});
</script>

