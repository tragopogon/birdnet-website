---
title: BirdNET Demo
layout: layouts/base.njk
permalink: "/demo/"
---

<div class="row mb-5 pb-lg-2">
  <div class="col-lg-8">
    <span class="section-label" data-i18n="demo.label">LIVE INFERENCE</span>
    <h1 class="page-title mb-4" data-i18n="demo.title">BirdNET Demo</h1>
    <p class="lead text-muted mb-0" data-i18n="demo.intro">
      Run BirdNET locally with TensorFlow.js. All audio is processed within your browser—nothing is uploaded.
    </p>
    <div class="text-muted small mt-4">
      <span data-i18n="demo.codeCredit">Code adapted from</span>
      <a href="https://github.com/georg95/birdnet-web" target="_blank" rel="noopener">georg95/birdnet-web</a>.
    </div>
  </div>
</div>

<div class="pt-2 pb-5">
    <!-- Upload form / dropzone -->
    <form id="fileform" class="mb-4" enctype="multipart/form-data">
      <div id="dropzone" class="upload-dropzone border border-dashed rounded bg-light overflow-hidden">
        
        <!-- Header bar (always visible, clickable to toggle) -->
        <div id="dropzoneHeader" class="dropzone-header d-none">
          <div class="d-flex align-items-center justify-content-between w-100">
            <div class="d-flex align-items-center gap-2 min-width-0">
              <i class="bi bi-file-earmark-music text-primary flex-shrink-0"></i>
              <span class="small" id="collapsedFileInfo">Audio loaded</span>
            </div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
              <button type="button" id="downloadRecordingBtn" class="btn btn-sm btn-outline-primary d-none" onclick="event.stopPropagation();">
                <i class="bi bi-download"></i>
              </button>
              <i class="bi bi-chevron-down dropzone-chevron"></i>
            </div>
          </div>
        </div>
        
        <!-- Expandable content area -->
        <div id="dropzoneContent" class="dropzone-content">
          <div class="text-center p-4">
            <i class="bi bi-cloud-arrow-up fs-1 text-muted mb-2 d-block"></i>
            <p class="mb-2 small text-muted" data-i18n="demo.dropzone.drag">Drag & drop audio or choose a file (48 kHz preferred, WAV/MP3)</p>
            <input id="fileupload" name="file" type="file" accept="audio/*, audio/mpeg, audio/wav, audio/aac" hidden>
            <div class="d-flex gap-2 justify-content-center flex-wrap">
              <button type="button" id="chooseBtn" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-folder2-open me-1"></i><span data-i18n="demo.dropzone.choose">Choose file</span>
              </button>
              <button type="button" id="loadSampleBtn" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-music-note-beamed me-1"></i><span data-i18n="demo.dropzone.sample">Try sample audio</span>
              </button>
              <button type="button" id="recordBtn" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-mic me-1"></i><span data-i18n="demo.dropzone.record">Record from mic</span>
              </button>
            </div>
            <div class="small mt-2 text-muted" id="fileInfo"></div>
          </div>
        </div>
        
        <!-- Recording UI (hidden by default) -->
        <div id="recordingUI" class="d-none">
          <div class="text-center p-4">
          <div class="recording-indicator mb-3">
            <span class="recording-dot"></span>
            <span class="fs-5 fw-medium text-danger" data-i18n="demo.recording.title">Recording...</span>
          </div>
          <div id="recordingTimer" class="fs-2 fw-bold mb-3">0:00</div>
          <div class="d-flex gap-2 justify-content-center">
            <button type="button" id="stopRecordBtn" class="btn btn-danger">
              <i class="bi bi-stop-fill me-1"></i><span data-i18n="demo.recording.stop">Stop Recording</span>
            </button>
            <button type="button" id="cancelRecordBtn" class="btn btn-outline-secondary">
              <i class="bi bi-x-lg me-1"></i><span data-i18n="demo.recording.cancel">Cancel</span>
            </button>
          </div>
          <div class="small mt-3 text-muted">
            <i class="bi bi-info-circle me-1"></i><span data-i18n="demo.recording.info">Recording at 48 kHz for best results. Max 5 minutes.</span>
          </div>
          </div>
        </div>
      </div>
    </form>

    <!-- Player / spectrogram area -->
    <div id="player" class="mb-3">
      <div class="spectro-wrapper" id="spectro-wrapper">
        <div id="ws-container" class="ws-container position-relative">
          <div id="playCursor"></div>
        </div>
        <div id="spectro-controls" class="spectro-controls d-none align-items-center gap-2 mt-3 flex-wrap">
          <button id="playBtn" class="btn btn-sm btn-primary" title="Play" aria-label="Play">▶</button>
          <button id="pauseBtn" class="btn btn-sm btn-primary btn-control" title="Pause" aria-label="Pause">❚❚</button>
            <button id="restartBtn" class="btn btn-sm btn-primary btn-control" title="Restart" aria-label="Restart">↺</button>
          <div id="timeDisplay" class="small text-white-50 ms-2">0:00 / 0:00</div>
        </div>
      </div>
    </div>

    <!-- Settings panel (hidden until audio loads) -->
    <div id="settingsPanel" class="card mb-3 d-none">
      <div class="card-body">
        <!-- Main controls row -->
        <div class="row g-3">
          <!-- Language selection -->
          <div class="col-12 col-md-4">
            <label for="langSelect" class="form-label small fw-medium mb-1">
              <i class="bi bi-translate me-1 text-muted"></i><span data-i18n="demo.settings.labels">Species labels</span>
            </label>
            <select id="langSelect" class="form-select form-select-sm">
              <option value="auto" selected>Auto (browser language)</option>
              <option value="en_us">English (US)</option>
              <option value="en_uk">English (UK)</option>
              <option value="de">Deutsch</option>
              <option value="fr">Français</option>
              <option value="es">Español</option>
              <option value="it">Italiano</option>
              <option value="nl">Nederlands</option>
              <option value="pt">Português</option>
              <option value="fi">Suomi</option>
              <option value="sv">Svenska</option>
              <option value="da">Dansk</option>
              <option value="no">Norsk</option>
              <option value="pl">Polski</option>
              <option value="cs">Čeština</option>
              <option value="sk">Slovenčina</option>
              <option value="ro">Română</option>
              <option value="sl">Slovenščina</option>
              <option value="hu">Magyar</option>
              <option value="ru">Русский</option>
              <option value="uk">Українська</option>
              <option value="tr">Türkçe</option>
              <option value="ar">العربية</option>
              <option value="ja">日本語</option>
              <option value="ko">한국어</option>
              <option value="th">ไทย</option>
              <option value="zh">中文</option>
            </select>
          </div>
          
          <!-- Overlap selection -->
          <div class="col-6 col-md-2">
            <label for="overlapSelect" class="form-label small fw-medium mb-1">
              <i class="bi bi-layers me-1 text-muted"></i><span data-i18n="demo.settings.overlap">Overlap</span>
            </label>
            <select id="overlapSelect" class="form-select form-select-sm">
              <option value="0.0" selected>0.0 s</option>
              <option value="0.5">0.5 s</option>
              <option value="1.0">1.0 s</option>
              <option value="1.5">1.5 s</option>
              <option value="2.0">2.0 s</option>
              <option value="2.5">2.5 s</option>
            </select>
          </div>
          
          <!-- Confidence threshold -->
          <div class="col-6 col-md-3">
            <label for="confidenceThreshold" class="form-label small fw-medium mb-1">
              <i class="bi bi-sliders me-1 text-muted"></i><span data-i18n="demo.settings.confidence">Min. confidence:</span> <span id="confidenceValue" class="text-primary">10%</span>
            </label>
            <input type="range" class="form-range" id="confidenceThreshold" min="0.01" max="0.99" step="0.01" value="0.10">
          </div>
          
          <!-- Run button -->
          <div class="col-12 col-md-3 d-flex align-items-end">
            <button type="button" id="runBtn" class="btn btn-primary w-100">
              <i class="bi bi-play-fill me-1"></i><span data-i18n="demo.settings.run">Run Analysis</span>
            </button>
          </div>
        </div>
        
        <!-- Location filter section -->
        <div class="mt-3 pt-3 border-top">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <label class="form-label small fw-medium mb-0">
              <i class="bi bi-geo-alt me-1 text-muted"></i><span data-i18n="demo.settings.location">Location filter</span>
              <span id="locationStatus" class="badge bg-secondary ms-2" data-i18n="demo.settings.locationOff">Off</span>
            </label>
            <div class="form-check form-switch mb-0">
              <input class="form-check-input" type="checkbox" id="useLocationFilter" role="switch">
              <label class="form-check-label small text-muted" for="useLocationFilter" data-i18n="demo.settings.enable">Enable</label>
            </div>
          </div>
          
          <div id="locationInputs" class="row g-2 align-items-end" style="display: none;">
            <div class="col">
              <input type="number" step="0.0001" id="latInput" class="form-control form-control-sm" placeholder="Latitude (e.g. 40.7812)">
            </div>
            <div class="col">
              <input type="number" step="0.0001" id="lonInput" class="form-control form-control-sm" placeholder="Longitude (e.g. -73.9665)">
            </div>
            <div class="col-auto">
              <button type="button" id="geolocateBtn" class="btn btn-sm btn-outline-primary" title="Use my current location">
                <i class="bi bi-crosshair me-1"></i><span data-i18n="demo.settings.detect">Detect</span>
              </button>
            </div>
          </div>
          
          <div id="locationHelp" class="small text-muted mt-2" style="display: none;">
            <i class="bi bi-info-circle me-1"></i>
            <span data-i18n="demo.locationHelp">Adding your location helps filter species to those likely in your area.</span>
          </div>
        </div>
      </div>
      
      <!-- Progress section (inside card, initially hidden) -->
      <div id="progressSection" class="card-footer bg-light d-none">
        <div class="d-flex align-items-center gap-3">
          <div class="flex-grow-1">
            <div class="progress" style="height: 8px;">
              <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
            </div>
          </div>
          <div id="progressText" class="small text-muted" style="min-width: 120px;">Initializing...</div>
        </div>
      </div>
    </div>

    <!-- Status line -->
    <div id="statusArea" class="mb-3">
      <div id="statusLine" class="small text-muted" data-i18n="demo.status.waitingAudio">Waiting for audio…</div>
    </div>

    <!-- Results: interactive species list -->
    <div id="results" class="mb-3"></div>

    <!-- Download button (hidden until segment data available) -->
    <div class="mb-4">
      <button id="downloadCsvBtn" class="btn btn-sm btn-outline-secondary d-none" disabled>
        <i class="bi bi-download me-1"></i><span data-i18n="demo.downloadCsv">Download CSV results</span>
      </button>
    </div>

  </div>
</div>

<!-- Local JS vendor bundles -->
<script src="{{ '/js/jquery-3.7.1.min.js' | url }}"></script>
<script src="{{ '/js/wavesurfer-7.min.js' | url }}"></script>
<script src="{{ '/js/wavesurfer.spectrogram.min.js' | url }}"></script>
<script src="{{ '/js/wavesurfer.minimap.min.js' | url }}"></script>

<!-- App logic -->
<script type="module">
/* -----------------------------
   Global state / configuration
----------------------------- */
const workerBase = '{{ "/js/birdnet-worker.js" | url }}';
const modelsRoot = '{{ "/models" | url }}';
const sampleAudioUrl = '{{ "/audio/XC1059662_Blue_Jay.mp3" | url }}';
const speciesImageBase = 'https://birdnet.cornell.edu/api2/bird/';

let worker = null;
let workerLoaded = false;
let resolveWhenLoaded = null;
let currentWorkerLang = null;
let ws = null;
let areaModelLoaded = false;
let lastPCM = null;
let segmentPredictions = null;
let pooledResults = null;
let currentFileName = 'audio';
let lastRecordingBlob = null; // Store recording for download

const WINDOW_SAMPLES = 144000; // 3s @ 48 kHz
const GEO_THRESH = 0.05;

// i18n helper - returns translation or fallback, never the key
function _t(key, fallback) {
  if (window.i18n && typeof window.i18n.t === 'function') {
    const result = window.i18n.t(key);
    // If t() returns the key itself, use fallback
    return result !== key ? result : fallback;
  }
  return fallback;
}

/* -----------------------------
   Progress helpers
----------------------------- */
function showProgress(percent, text) {
  $('#progressSection').removeClass('d-none');
  $('#progressBar').css('width', percent + '%');
  if (text) $('#progressText').text(text);
}

function hideProgress() {
  $('#progressSection').addClass('d-none');
  $('#progressBar').css('width', '0%');
}

function setRunButtonLoading(loading) {
  const btn = $('#runBtn');
  if (loading) {
    btn.prop('disabled', true).html('<i class="bi bi-arrow-repeat spin me-1"></i>' + _t('demo.status.analyzingBtn', 'Analyzing...'));
  } else {
    btn.prop('disabled', false).html('<i class="bi bi-play-fill me-1"></i>' + _t('demo.settings.run', 'Run Analysis'));
  }
}

/* -----------------------------
   Location filter helpers
----------------------------- */
function isLocationFilterEnabled() {
  return $('#useLocationFilter').is(':checked');
}

function hasValidLocation() {
  const lat = parseFloat($('#latInput').val());
  const lon = parseFloat($('#lonInput').val());
  return !Number.isNaN(lat) && !Number.isNaN(lon);
}

function updateLocationStatus() {
  const enabled = isLocationFilterEnabled();
  const hasCoords = hasValidLocation();
  const badge = $('#locationStatus');
  
  if (!enabled) {
    badge.removeClass('bg-success bg-warning').addClass('bg-secondary').text('Off');
  } else if (hasCoords) {
    badge.removeClass('bg-secondary bg-warning').addClass('bg-success').text('Active');
  } else {
    badge.removeClass('bg-secondary bg-success').addClass('bg-warning').text('No coordinates');
  }
}

/* -----------------------------
   Worker URL builder
----------------------------- */
function makeWorkerUrl(selectedLang) {
  const qs = new URLSearchParams({ root: modelsRoot });
  if (selectedLang && selectedLang !== 'auto') qs.set('lang', selectedLang);
  qs.set('tf', '{{ "/js/tfjs-4.14.0.min.js" | url }}');
  return workerBase + '?' + qs.toString();
}

/* -----------------------------
   Worker setup / lifecycle
----------------------------- */
function attachWorker() {
  worker.onmessage = ({ data }) => {
    if(['load_model','warmup','load_geomodel','load_labels'].includes(data.message)){
      const progress = data.progress ?? 0;
      let stepText = _t('demo.status.loadModel', 'Loading model...');
      if (data.message === 'load_model') stepText = _t('demo.status.loadModel', 'Loading neural network...');
      if (data.message === 'warmup') stepText = _t('demo.status.warmup', 'Warming up model...');
      if (data.message === 'load_geomodel') stepText = _t('demo.status.loadGeo', 'Loading geo model...');
      if (data.message === 'load_labels') stepText = _t('demo.status.loadLabels', 'Loading species labels...');
      showProgress(Math.min(progress * 0.4, 40), stepText);
    }
    if(data.message === 'loaded'){
      workerLoaded = true;
      showProgress(45, _t('demo.status.modelReady', 'Model ready'));
      if (resolveWhenLoaded) { resolveWhenLoaded(); resolveWhenLoaded = null; }
    }
    if(data.message === 'predict_debug'){
      console.groupCollapsed('[birdnet] top-10 per batch');
      data.top10PerBatch.forEach(({ batch, max, mean, top10 }) => {
        console.groupCollapsed(`batch ${batch} · max=${max.toFixed(4)} · mean=${mean.toExponential(2)}`);
        console.table(top10.map(t => ({ name: t.name, confidence: +t.confidence.toFixed(4) })));
        console.groupEnd();
      });
      console.groupEnd();
    }
    if(data.message === 'segments'){
      segmentPredictions = data.segments;
      showProgress(90, _t('demo.status.processing', 'Processing results...'));
      $('#downloadCsvBtn').prop('disabled', false).removeClass('d-none');
    }
    if(data.message === 'pooled'){
      showProgress(100, _t('demo.status.complete', 'Complete!'));
      setTimeout(() => {
        hideProgress();
        setRunButtonLoading(false);
      }, 400);
      
      const useGeo = areaModelLoaded && isLocationFilterEnabled();
      pooledResults = data.pooled.map(x => {
        const filtered = useGeo ? (x.geoscore > GEO_THRESH ? x.confidence : 0) : x.confidence;
        return { ...x, filtered };
      }).sort((a,b) => b.filtered - a.filtered);
      renderResults();
      const completeMsg = _t('demo.status.analysisComplete', 'Analysis complete. Click a species to see detections.');
      $('#statusLine').html('<i class="bi bi-check-circle text-success me-1"></i>' + completeMsg);
    }
    if(data.message === 'area-scores'){
      areaModelLoaded = true;
      showProgress(55, _t('demo.status.geoApplied', 'Geo filter applied'));
    }
  };
}

function newWorker(selectedLang) {
  if (worker) { try { worker.terminate(); } catch{} }
  workerLoaded = false;
  areaModelLoaded = false;
  currentWorkerLang = selectedLang || 'auto';
  worker = new Worker(makeWorkerUrl(currentWorkerLang));
  attachWorker();
}

function waitForLoaded(){
  if (workerLoaded) return Promise.resolve();
  return new Promise(res => { resolveWhenLoaded = res; });
}

/* -----------------------------
   Utility functions
----------------------------- */
function fmtTime(sec){
  if(!sec||isNaN(sec)) return '0:00';
  const m=Math.floor(sec/60);
  const s=Math.floor(sec%60);
  return m+':'+String(s).padStart(2,'0');
}

function fmtTimeDetailed(sec){
  if(!sec||isNaN(sec)) return '0:00.0';
  const m=Math.floor(sec/60);
  const s=(sec%60).toFixed(1);
  return m+':'+String(s).padStart(4,'0');
}

function getSpeciesImageUrl(scientificName) {
  if (!scientificName) return null;
  return speciesImageBase + encodeURIComponent(scientificName) + '.webp';
}

function getConfidenceThreshold() {
  return parseFloat($('#confidenceThreshold').val()) || 0.1;
}

/* -----------------------------
   WaveSurfer + Spectrogram init
----------------------------- */
let currentObjectUrl = null;

function initWaveSurfer(url){
  if(ws){ try{ ws.destroy(); } catch{} ws=null; }
  // Revoke previous object URL to free memory (critical on iOS)
  if (currentObjectUrl) { URL.revokeObjectURL(currentObjectUrl); currentObjectUrl = null; }
  if (url.startsWith('blob:')) currentObjectUrl = url;
  $('#spectro-controls').addClass('d-none');
  const SpectrogramPlugin = WaveSurfer.Spectrogram;
  const MinimapPlugin = WaveSurfer.Minimap;
  ws = WaveSurfer.create({
    container:'#ws-container',
    url,
    height:0,
    sampleRate:48000,
    waveColor:'transparent',
    progressColor:'transparent',
    cursorWidth:0
  });
  if(MinimapPlugin){
    ws.registerPlugin(MinimapPlugin.create({
      height:30, waveColor:'#a89f98', progressColor:'#2E261F', normalize:true
    }));
  }
  if(SpectrogramPlugin){
    ws.registerPlugin(SpectrogramPlugin.create({
      frequencyMax:12000, frequencyMin:300, fftSamples:512, labels:false,
      splitChannels:false, height:150, scale:'linear', colorMap:'roseus',
      gainDB:35, rangeDB:100
    }));
  }
  ws.on('ready',()=>{
    $('#timeDisplay').text('0:00 / '+fmtTime(ws.getDuration()));
    $('#spectro-controls').removeClass('d-none').addClass('d-flex');
    $('#settingsPanel').removeClass('d-none');
  });
  ws.on('audioprocess',t=>$('#timeDisplay').text(fmtTime(t)+' / '+fmtTime(ws.getDuration())));
  ws.on('seek',()=>$('#timeDisplay').text(fmtTime(ws.getCurrentTime())+' / '+fmtTime(ws.getDuration())));
}

/* -----------------------------
   Results rendering
----------------------------- */
function renderResults() {
  if (!pooledResults) return;
  
  const threshold = getConfidenceThreshold();
  const useGeo = areaModelLoaded && isLocationFilterEnabled() && hasValidLocation();
  const valueKey = useGeo ? 'filtered' : 'confidence';
  
  // Filter and limit to top 15
  const items = pooledResults
    .filter(x => x[valueKey] >= threshold)
    .slice(0, 15);
  
  if (items.length === 0) {
    $('#results').html(`
      <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        No species detected above the confidence threshold (${(threshold * 100).toFixed(0)}%). 
        Try lowering the threshold or using a different audio file.
      </div>
    `);
    return;
  }
  
  // Show info about location filter
  let filterInfo = '';
  if (useGeo) {
    filterInfo = `<div class="alert alert-light border small mb-3">
      <i class="bi bi-geo-alt-fill text-success me-1"></i>
      Results filtered by location. Species unlikely to occur at your coordinates are hidden.
    </div>`;
  }
  
  let html = filterInfo + '<div class="species-results">';
  
  items.forEach((item, idx) => {
    // Use sciName from worker (already parsed from "Scientific Name_Common Name" format)
    const scientificName = item.sciName || item.name;
    // Use localized name if available, otherwise fall back to common name
    const displayName = item.nameI18n || item.name || scientificName;
    const confidence = item[valueKey];
    const confidencePercent = (confidence * 100).toFixed(1);
    const imageUrl = getSpeciesImageUrl(scientificName);
    
    // Find segments where this species was detected
    const segments = getSegmentsForSpecies(scientificName, threshold);
    
    html += `
      <div class="species-card card mb-2" data-species="${scientificName}">
        <div class="card-body p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="species-image-wrapper">
              <img src="${imageUrl}" 
                   alt="${displayName}" 
                   class="species-image rounded"
                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
              <div class="species-image-placeholder rounded" style="display:none;">
                <i class="bi bi-card-image text-muted"></i>
              </div>
            </div>
            <div class="flex-grow-1 min-width-0">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <h6 class="mb-0 species-name">${displayName}</h6>
                  <small class="text-muted fst-italic">${scientificName}</small>
                </div>
                <div class="text-end">
                  <span class="badge bg-primary">${confidencePercent}%</span>
                  ${segments.length > 0 ? `<div class="small text-muted mt-1">${segments.length} detection${segments.length > 1 ? 's' : ''}</div>` : ''}
                </div>
              </div>
              <div class="progress mt-2" style="height: 4px;">
                <div class="progress-bar" role="progressbar" style="width: ${confidencePercent}%"></div>
              </div>
            </div>
            <button class="btn btn-sm btn-link text-muted expand-btn p-0" type="button" data-bs-toggle="collapse" data-bs-target="#segments-${idx}">
              <i class="bi bi-chevron-down"></i>
            </button>
          </div>
          
          <!-- Expandable segment details -->
          <div class="collapse" id="segments-${idx}">
            <div class="segment-list mt-3 pt-3 border-top">
              ${segments.length > 0 ? segments.map(seg => `
                <div class="segment-item d-flex align-items-center gap-2 py-1 px-2 rounded hover-bg" 
                     data-start="${seg.start}" data-end="${seg.end}">
                  <button class="btn btn-sm btn-outline-primary play-segment-btn" title="Play segment">
                    <i class="bi bi-play-fill"></i>
                  </button>
                  <span class="small text-muted">${fmtTimeDetailed(seg.start)} – ${fmtTimeDetailed(seg.end)}</span>
                  <span class="badge bg-secondary ms-auto">${(seg.confidence * 100).toFixed(1)}%</span>
                </div>
              `).join('') : '<div class="small text-muted">No individual segment detections above threshold.</div>'}
            </div>
          </div>
        </div>
      </div>
    `;
  });
  
  html += '</div>';
  $('#results').html(html);
  
  // Attach event listeners for segment playback
  $('.play-segment-btn').on('click', function(e) {
    e.stopPropagation();
    const segmentItem = $(this).closest('.segment-item');
    const startTime = parseFloat(segmentItem.data('start'));
    if (ws && !isNaN(startTime)) {
      const duration = ws.getDuration();
      ws.seekTo(startTime / duration);
      ws.play();
      // Auto-stop after ~3.5 seconds (segment duration + buffer)
      setTimeout(() => {
        if (ws.isPlaying()) ws.pause();
      }, 3500);
    }
  });
  
  // Toggle chevron on expand/collapse
  $('.species-card').on('show.bs.collapse', function() {
    $(this).find('.expand-btn i').removeClass('bi-chevron-down').addClass('bi-chevron-up');
  }).on('hide.bs.collapse', function() {
    $(this).find('.expand-btn i').removeClass('bi-chevron-up').addClass('bi-chevron-down');
  });
}

function getSegmentsForSpecies(sciName, threshold) {
  if (!segmentPredictions) return [];
  
  const segments = [];
  const useGeo = areaModelLoaded && isLocationFilterEnabled() && hasValidLocation();
  
  segmentPredictions.forEach(seg => {
    const match = seg.preds.find(p => p.sciName === sciName);
    if (match) {
      const conf = useGeo && match.geoscore <= GEO_THRESH ? 0 : match.confidence;
      if (conf >= threshold) {
        segments.push({
          start: seg.start,
          end: seg.end,
          confidence: conf
        });
      }
    }
  });
  
  return segments.sort((a, b) => b.confidence - a.confidence);
}

