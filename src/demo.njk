async function loadAudioFile(file, isRecording = false) {
  clearResults();
  currentFileName = file.name.replace(/\.[^/.]+$/, '');
  const fileInfoText = file.name + ' (' + (file.size/1024/1024).toFixed(2) + ' MB)';
  $('#fileInfo').text(fileInfoText);
  $('#collapsedFileInfo').html('<strong>' + file.name + '</strong> <span class="text-muted">(' + (file.size/1024/1024).toFixed(2) + ' MB)</span>');
  initWaveSurfer(URL.createObjectURL(file));
  showProgress(30, _t('demo.status.decodingAudio', 'Decoding audio...'));
  
  // Collapse dropzone
  collapseDropzone();
  
  // Show/hide recording download button
  if (isRecording) {
    $('#downloadRecordingBtn').removeClass('d-none');
  } else {
    lastRecordingBlob = null;
    $('#downloadRecordingBtn').addClass('d-none');
  }
  try {
    const { pcm } = await fileToPCMWindows(file);
    lastPCM = pcm;
    showProgress(100, _t('demo.status.ready', 'Ready'));
    setTimeout(hideProgress, 300);
    $('#statusLine').html('<i class="bi bi-check-circle text-success me-1"></i>' + _t('demo.status.audioLoaded', 'Audio loaded. Adjust settings and click <strong>Run Analysis</strong>.'));
  } catch (err) {
    hideProgress();
    $('#statusLine').html('<span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Error decoding audio: ' + err.message + '</span>');
  }
}

