<!-- Stats fetch script (moved to very end, after all DOM elements) -->
<script>
(function(){
  const STATS_URL = 'https://birdnet.cornell.edu/api2/requeststats';
  const REFRESH_MS = 5 * 60 * 1000;
  let refreshTimer = null;

  function fmtInt(v){
    return (typeof v === 'number' && isFinite(v)) ? v.toLocaleString('en-US') : '0';
  }

  async function fetchStats(){
    try {
      const res = await fetch(STATS_URL, { cache: 'no-store', credentials: 'omit' });
      if(!res.ok){
        throw new Error('HTTP '+res.status+' '+res.statusText);
      }
      const data = await res.json();
      processStats(data);
    } catch (e){
      console.error('Stats fetch failed:', e);
      const el = document.getElementById('stats-updated');
      if(el) el.textContent = 'Failed to load stats.';
    }
  }

  function processStats(data){
    const observationsRaw = Array.isArray(data.observations) ? data.observations : [];
    const observationsSorted = observationsRaw.slice().sort((a,b)=>(+b.ts)-(+a.ts));
    const now = Date.now();
    const dayAgo = now - 24*3600*1000;
    const obs24h = observationsSorted.filter(o => +o.ts >= dayAgo);
    const statsObj = (data.stats && typeof data.stats === 'object') ? data.stats : {};

    const totalObservations = statsObj.total_observations ?? observationsSorted.length;
    const observations24h = statsObj.observations ?? obs24h.length;
    const users24h = statsObj.users ?? 0;

    const speciesSet = new Set();
    for (const o of obs24h){
      if(typeof o.species === 'string'){
        const common = o.species.split(';')[0] || o.species;
        speciesSet.add(common);
      }
    }
    const species24h = speciesSet.size;

    // Guard each update in case IDs were reordered/removed
    const setText = (id,val)=> {
      const el = document.getElementById(id);
      if(el) el.textContent = val;
    };
    setText('stat-total-observations', fmtInt(totalObservations));
    setText('stat-observations-24h', fmtInt(observations24h));
    setText('stat-species-24h', fmtInt(species24h));
    setText('stat-users-24h', fmtInt(users24h));
    setText('stats-updated', 'Updated ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));

    clearTimeout(refreshTimer);
    refreshTimer = setTimeout(fetchStats, REFRESH_MS);
  }

  function init(){
    fetchStats();
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>