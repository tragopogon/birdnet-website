                <h2 class="h5 card-title mb-1">BirdNET-Analyzer</h2>
                <p class="small text-muted mb-2">Python · Gradio</p>
                <p class="text-muted small flex-grow-1">
                  Main analysis engine for applying BirdNET models to scientific audio data, from small projects to
                  large-scale monitoring.
                </p>
                <a href="https://github.com/birdnet-team/BirdNET-Analyzer" class="stretched-link small" data-i18n="tools.viewOnGithub">
                  View on GitHub
                </a>
              </div>
            </div>
          </div>

          <!-- birdnet -->
          <div class="col">
            <div class="card h-100 shadow-sm">
              <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title mb-1">birdnet</h2>
                <p class="small text-muted mb-2">Python</p>
                <p class="text-muted small flex-grow-1">
                  A Python library for identifying bird species by sound, focused on robust workflows for ecological
                  data analysis.
                </p>
                <a href="https://github.com/birdnet-team/birdnet" class="stretched-link small" data-i18n="tools.viewOnGithub">
                  View on GitHub
                </a>
              </div>
            </div>
